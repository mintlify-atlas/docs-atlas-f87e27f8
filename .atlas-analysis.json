    "mod_exelearning_manage_embedded_editor_status",
    "track::ingest() — shared scoring pipeline",
    "grade_sync::sync() — grade-item synchronisation",
    "embedded_editor_installer — install/update/repair/uninstall editor",
    "package::detect_gradable_idevices() — iDevice detection from content.xml"
  ]
