  "keyFeatures": [
    "Embed eXeLearning v4 (.elpx) packages inside Moodle with native sidebar navigation preserved",
    "Per-iDevice gradebook columns — one column per gradable exercise, or a single aggregated overall",
    "In-browser embedded eXeLearning editor with postMessage save-to-Moodle bridge",
    "Multi-attempt support with configurable aggregation (highest, average, first, last, lowest)",
    "SCORM 1.2 window.API shim for score reporting from unmodified eXeLearning exports",
    "Full Moodle App web-service API (MOODLE_OFFICIAL_MOBILE_SERVICE)",
    "GDPR-compliant privacy provider with attempt export and deletion + grade recalculation",
    "Backup and restore support including grade-item mappings and attempt history",
    "Completion by passing grade (SCORM-style) and custom completion by attempt status",
    "Secure XML parsing with XXE and billion-laughs defences",
    "Migration tool from mod_exeweb / mod_exescorm sibling plugins"
  ],
  "publicApiSurface": [
    "mod_exelearning_get_exelearnings_by_courses",
    "mod_exelearning_view_exelearning",
    "mod_exelearning_get_exelearning_access_information",
    "mod_exelearning_get_user_attempts",
